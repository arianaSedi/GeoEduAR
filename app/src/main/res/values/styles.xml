<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Button" parent="Widget.Material3.Button">

        <item name="cornerRadius">12dp</item>
        <item name="android:padding">12dp</item>

        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>

    </style>

    <style name="TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">

        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>

    </style>

    <style name="CardLogin" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">8dp</item>
    </style>
</resources>